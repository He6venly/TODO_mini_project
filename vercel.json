{
  "version": 2,
  "builds": [
    { "src": "frontEnd/package.json", "use": "@vercel/static-build" },
    { "src": "backEnd/index.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backEnd/index.js" },
    { "source": "/(.*)", "destination": "/frontEnd/$1" } 
  ]
}